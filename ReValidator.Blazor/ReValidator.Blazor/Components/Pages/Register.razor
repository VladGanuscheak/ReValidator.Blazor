@page "/register"
@using System.Net.Http.Json
@using ReValidator.Shared.Models
@using ReValidator.BlazorAdapter
@inject IHttpClientFactory HttpClientFactory
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Register</PageTitle>

<h1>Register</h1>
<p class="text-muted">Demonstrates ReValidator with cross-field validation (password match), range checks, and checkbox rules.</p>

<div class="row">
    <div class="col-md-6">
        <EditForm EditContext="editContext" OnValidSubmit="HandleValidSubmit">
            <ReValidatorComponent TModel="RegisterModel" />

            <div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <InputText id="username" class="form-control" @bind-Value="model.Username" />
                <ValidationMessage For="() => model.Username" />
            </div>

            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <InputText id="email" class="form-control" @bind-Value="model.Email" />
                <ValidationMessage For="() => model.Email" />
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <InputText id="password" type="password" class="form-control" @bind-Value="model.Password" />
                <ValidationMessage For="() => model.Password" />
            </div>

            <div class="mb-3">
                <label for="confirmPassword" class="form-label">Confirm Password</label>
                <InputText id="confirmPassword" type="password" class="form-control" @bind-Value="model.ConfirmPassword" />
                <ValidationMessage For="() => model.ConfirmPassword" />
            </div>

            <div class="mb-3">
                <label for="age" class="form-label">Age</label>
                <InputNumber id="age" class="form-control" @bind-Value="model.Age" />
                <ValidationMessage For="() => model.Age" />
            </div>

            <div class="mb-3 form-check">
                <InputCheckbox id="acceptTerms" class="form-check-input" @bind-Value="model.AcceptTerms" />
                <label for="acceptTerms" class="form-check-label">I accept the terms and conditions</label>
                <ValidationMessage For="() => model.AcceptTerms" />
            </div>

            <button type="submit" class="btn btn-primary" disabled="@submitting">
                @if (submitting)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    @:Registering…
                }
                else
                {
                    @:Register
                }
            </button>
            <button type="button" class="btn btn-outline-secondary ms-2" @onclick="Reset">Reset</button>

            <div class="card mt-3">
                <div class="card-header">Validation Summary</div>
                <div class="card-body">
                    <ValidationSummary />
                </div>
            </div>
        </EditForm>
    </div>
    <div class="col-md-6">
        @if (apiResponse is not null)
        {
            <div class="card mt-3 border-@(apiResponse.IsSuccess ? "success" : "danger")">
                <div class="card-header text-bg-@(apiResponse.IsSuccess ? "success" : "danger")">
                    API Response &mdash; @apiResponse.StatusCode
                </div>
                <div class="card-body">
                    <pre class="mb-0"><code>@apiResponse.Body</code></pre>
                </div>
            </div>
        }

        @if (apiError is not null)
        {
            <div class="alert alert-danger mt-3">
                <strong>API Error:</strong> @apiError
            </div>
        }

        @if (submitted)
        {
            <div class="alert alert-success mt-3">
                <strong>Registration successful!</strong> Welcome, <em>@submittedUsername</em>.
            </div>
        }
    </div>
</div>

@code {
    private RegisterModel model = new();
    private EditContext editContext = null!;
    private ValidationMessageStore serverMessageStore = null!;
    private bool submitted;
    private bool submitting;
    private string submittedUsername = string.Empty;
    private string? apiError;
    private ApiResponseInfo? apiResponse;

    protected override void OnInitialized()
    {
        editContext = new EditContext(model);
        serverMessageStore = new ValidationMessageStore(editContext);
    }

    private async Task HandleValidSubmit()
    {
        serverMessageStore.Clear();
        editContext.NotifyValidationStateChanged();
        submitted = false;
        apiError = null;
        apiResponse = null;
        submitting = true;

        try
        {
            var client = HttpClientFactory.CreateClient("ReValidatorApi");
            var response = await client.PostAsJsonAsync("/api/register", model);
            var body = await response.Content.ReadAsStringAsync();

            apiResponse = new ApiResponseInfo(
                (int)response.StatusCode,
                response.IsSuccessStatusCode,
                body);

            if (ServerValidationInterop.HandleResponse(response, body, editContext, serverMessageStore))
            {
                submittedUsername = model.Username;
                submitted = true;
            }
        }
        catch (HttpRequestException ex)
        {
            apiError = $"Could not reach the API. Is ReValidator.Api running? ({ex.Message})";
        }
        finally
        {
            submitting = false;
        }
    }

    private void Reset()
    {
        model = new();
        editContext = new EditContext(model);
        serverMessageStore = new ValidationMessageStore(editContext);
        submitted = false;
        apiError = null;
        apiResponse = null;
    }

    private sealed record ApiResponseInfo(int StatusCode, bool IsSuccess, string Body);
}
